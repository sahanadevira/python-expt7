items = []

print("Enter 4 items to create your mixed tuple:")
# element 1: A Number
num_input = int(input("1. Enter a number (e.g., 10): "))
items.append(num_input)

# element 2: A String
str_input = input("2. Enter a string (e.g., Hello): ")
items.append(str_input)

# element 3: A List
list_input = input("3. Enter numbers for a list, separated by spaces (e.g., 1 2 3): ").split()
items.append(list_input)

# element 4: A Tuple
tuple_input = tuple(input("4. Enter items for a nested tuple, separated by spaces: ").split())
items.append(tuple_input)

final_tuple = tuple(items)

print("\nYour Created Tuple:", final_tuple)
print("The length of the tuple is:", len(final_tuple))
